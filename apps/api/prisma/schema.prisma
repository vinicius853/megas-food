generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  internalCode String? @unique
  name      String
  responsibleName String?
  document  String?
  phone     String?
  whatsapp  String?
  city      String?
  state     String?
  address   String?
  zipCode   String?
  internalNotes String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  categories Category[]
  products   Product[]
  orders     Order[]
  coupons    Coupon[]
  billingInvoices BillingInvoice[]
  subscriptions   Subscription[]

  @@map("tenants")
}

model TenantInternalCodeSequence {
  id        String   @id @default(uuid())
  prefix    String   @unique
  nextValue Int      @default(1)
  updatedAt DateTime @updatedAt

  @@map("tenant_internal_code_sequences")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String
  password  String
  role      UserRole
  permissions String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@map("users")
}

model AuditLog {
  id         String        @id @default(uuid())
  actorId    String?
  actorEmail String?
  action     String
  target     String
  level      AuditLogLevel @default(INFO)
  metadata   Json?
  createdAt  DateTime      @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
  @@map("audit_logs")
}

model BillingInvoice {
  id                         String                @id @default(uuid())
  tenantId                   String
  planId                     String?
  subscriptionId             String?
  amount                     Decimal               @db.Decimal(10, 2)
  dueDate                    DateTime
  status                     BillingInvoiceStatus  @default(OPEN)
  paymentMethod              BillingPaymentMethod?
  mercadoPagoPreferenceId    String?
  mercadoPagoPaymentId       String?
  mercadoPagoPaymentStatus   String?
  paymentUrl                 String?
  sandboxPaymentUrl          String?
  notes                      String?
  paidAt                     DateTime?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan         Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([planId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@unique([mercadoPagoPreferenceId])
  @@unique([mercadoPagoPaymentId])
  @@map("billing_invoices")
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  monthlyPrice Decimal  @db.Decimal(10, 2)
  annualPrice  Decimal? @db.Decimal(10, 2)
  setupFee     Decimal? @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  features     String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions   Subscription[]
  billingInvoices BillingInvoice[]

  @@map("plans")
}

model Subscription {
  id                         String             @id @default(uuid())
  tenantId                   String
  planId                     String
  mercadoPagoSubscriptionId  String?
  mercadoPagoSubscriptionUrl String?
  mercadoPagoSubscriptionStatus String?
  status                     SubscriptionStatus @default(PENDING)
  contractedMonthlyPrice     Decimal            @db.Decimal(10, 2)
  contractedAnnualPrice      Decimal?           @db.Decimal(10, 2)
  contractedSetupFee         Decimal?           @db.Decimal(10, 2)
  contractedAt               DateTime           @default(now())
  internalNotes              String?
  startedAt                  DateTime?
  nextBillingDate            DateTime?
  canceledAt                 DateTime?
  accessUntil                DateTime?
  gracePeriodDays            Int                @default(5)
  blockedAt                  DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  billingInvoices BillingInvoice[]

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([nextBillingDate])
  @@unique([mercadoPagoSubscriptionId])
  @@map("subscriptions")
}

model PaymentWebhookLog {
  id          String   @id @default(uuid())
  provider    String
  eventId     String?
  eventType   String?
  resourceId  String?
  payload     Json?
  processed   Boolean  @default(false)
  error       String?
  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@index([provider])
  @@index([resourceId])
  @@unique([provider, eventId])
  @@map("payment_webhook_logs")
}

model Category {
  id        String       @id @default(uuid())
  tenantId  String
  name      String
  slug      String
  type      CategoryType @default(PRODUCT_SECTION)
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products     Product[]
  pizzaFlavors PizzaFlavor[]

  @@unique([tenantId, slug])
  @@map("categories")
}

model Product {
  id          String      @id @default(uuid())
  tenantId    String
  categoryId  String
  name        String
  description String?
  imageUrl    String?
  type        ProductType
  price       Decimal?    @db.Decimal(10, 2)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  sizes        PizzaSize[]
  flavorPrices PizzaFlavorPrice[]
  borderPrices PizzaBorderPrice[]
  orderItems   OrderItem[]

  @@map("products")
}

model PizzaSize {
  id          String        @id @default(uuid())
  tenantId    String
  productId   String
  name        String
  subtitle    String?
  type        PizzaSizeType
  value       Int?
  maxFlavors  Int           @default(1)
  allowBorder Boolean       @default(true)
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  flavorPrices PizzaFlavorPrice[]
  borderPrices PizzaBorderPrice[]

  @@map("pizza_sizes")
}

model PizzaFlavor {
  id          String   @id @default(uuid())
  tenantId    String
  categoryId  String?
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  prices     PizzaFlavorPrice[]
  orderItems OrderItemFlavor[]

  @@unique([tenantId, name])
  @@map("pizza_flavors")
}

model PizzaFlavorPrice {
  id        String  @id @default(uuid())
  tenantId  String
  productId String
  sizeId    String
  flavorId  String
  price     Decimal @db.Decimal(10, 2)

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size    PizzaSize   @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  flavor  PizzaFlavor @relation(fields: [flavorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, sizeId, flavorId])
  @@map("pizza_flavor_prices")
}

model PizzaBorder {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices PizzaBorderPrice[]

  @@unique([tenantId, name])
  @@map("pizza_borders")
}

model PizzaBorderPrice {
  id        String  @id @default(uuid())
  tenantId  String
  productId String
  sizeId    String
  borderId  String
  price     Decimal @db.Decimal(10, 2)

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size    PizzaSize   @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  border  PizzaBorder @relation(fields: [borderId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, sizeId, borderId])
  @@map("pizza_border_prices")
}

model Order {
  id            String       @id @default(uuid())
  tenantId      String
  userId        String?
  number        Int          @default(autoincrement())
  customerName  String?
  customerPhone String?
  type          OrderType
  status        OrderStatus  @default(PENDING)
  paymentType   PaymentType?
  subtotal      Decimal      @db.Decimal(10, 2)
  deliveryFee   Decimal      @default(0) @db.Decimal(10, 2)
  discountAmount Decimal      @default(0) @db.Decimal(10, 2)
  couponCode    String?
  totalBeforeDiscount Decimal? @db.Decimal(10, 2)
  total         Decimal      @db.Decimal(10, 2)
  notes         String?
  paidAt        DateTime?
  closedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  items OrderItem[]

  @@map("orders")
}

model Coupon {
  id                String       @id @default(uuid())
  tenantId          String
  code              String
  type              CouponType
  value             Decimal      @db.Decimal(10, 2)
  minimumOrderValue Decimal?     @db.Decimal(10, 2)
  startsAt          DateTime?
  expiresAt         DateTime?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("coupons")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  productId  String?
  sizeId     String?
  borderId   String?
  name       String
  sizeName   String?
  borderName String?
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)
  notes      String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  flavors OrderItemFlavor[]

  @@map("order_items")
}

model OrderItemFlavor {
  id          String  @id @default(uuid())
  orderItemId String
  flavorId    String?
  flavorName  String
  fraction    Decimal @db.Decimal(5, 2)

  orderItem OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  flavor    PizzaFlavor? @relation(fields: [flavorId], references: [id], onDelete: SetNull)

  @@map("order_item_flavors")
}

enum CategoryType {
  PRODUCT_SECTION
  PIZZA_FLAVOR_GROUP
}

enum UserRole {
  MASTER_OWNER
  MASTER_ADMIN
  FINANCE_ADMIN
  SUPPORT
  CLIENT_OWNER
  CLIENT_ADMIN
  CASHIER
}

enum ProductType {
  PIZZA_ROUND
  PIZZA_SQUARE
  DRINK
  OTHER
}

enum PizzaSizeType {
  CM
  SLICES
  CUSTOM
}

enum OrderType {
  ONLINE
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentType {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum AuditLogLevel {
  INFO
  WARNING
  CRITICAL
}

enum BillingInvoiceStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

enum BillingPaymentMethod {
  MERCADO_PAGO
  MANUAL
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCEL_SCHEDULED
  CANCELED
  BLOCKED
}
