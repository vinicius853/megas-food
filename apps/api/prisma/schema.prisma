generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id              String   @id @default(uuid())
  slug            String   @unique
  internalCode    String?  @unique
  name            String
  responsibleName String?
  document        String?
  phone           String?
  whatsapp        String?
  city            String?
  state           String?
  address         String?
  zipCode         String?
  internalNotes   String?
  logoUrl         String?
  isActive        Boolean         @default(true)
  enabledSegments TenantSegment[] @default([PIZZARIA])
  settings        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  users                      User[]
  categories                 Category[]
  products                   Product[]
  orders                     Order[]
  coupons                    Coupon[]
  billingInvoices            BillingInvoice[]
  subscriptions              Subscription[]
  modifierGroups             ModifierGroup[]
  modifierOptions            ModifierOption[]
  productModifierGroups      ProductModifierGroup[]
  productModifierOptions     ProductModifierOption[]
  productModifierOptionRules ProductModifierOptionRule[]
  modifierOptionPrices       ModifierOptionPrice[]
  whatsappConnection         WhatsAppConnection?
  whatsappNotifications      WhatsAppNotification[]

  @@map("tenants")
}

model TenantInternalCodeSequence {
  id        String   @id @default(uuid())
  prefix    String   @unique
  nextValue Int      @default(1)
  updatedAt DateTime @updatedAt

  @@map("tenant_internal_code_sequences")
}

model User {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  email       String
  password    String
  role        UserRole
  permissions String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders    Order[]
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@map("users")
}

model AuditLog {
  id         String        @id @default(uuid())
  actorId    String?
  actorEmail String?
  action     String
  target     String
  level      AuditLogLevel @default(INFO)
  metadata   Json?
  createdAt  DateTime      @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
  @@map("audit_logs")
}

model BillingInvoice {
  id                       String                @id @default(uuid())
  tenantId                 String
  planId                   String?
  subscriptionId           String?
  amount                   Decimal               @db.Decimal(10, 2)
  dueDate                  DateTime
  status                   BillingInvoiceStatus  @default(OPEN)
  paymentMethod            BillingPaymentMethod?
  mercadoPagoPreferenceId  String?
  mercadoPagoPaymentId     String?
  mercadoPagoPaymentStatus String?
  paymentUrl               String?
  sandboxPaymentUrl        String?
  notes                    String?
  paidAt                   DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan         Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([mercadoPagoPreferenceId])
  @@unique([mercadoPagoPaymentId])
  @@index([tenantId])
  @@index([planId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@map("billing_invoices")
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  monthlyPrice Decimal  @db.Decimal(10, 2)
  annualPrice  Decimal? @db.Decimal(10, 2)
  setupFee     Decimal? @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  features     String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions   Subscription[]
  billingInvoices BillingInvoice[]

  @@map("plans")
}

model Subscription {
  id                            String             @id @default(uuid())
  tenantId                      String
  planId                        String
  mercadoPagoSubscriptionId     String?
  mercadoPagoSubscriptionUrl    String?
  mercadoPagoSubscriptionStatus String?
  status                        SubscriptionStatus @default(PENDING)
  contractedMonthlyPrice        Decimal            @db.Decimal(10, 2)
  contractedAnnualPrice         Decimal?           @db.Decimal(10, 2)
  contractedSetupFee            Decimal?           @db.Decimal(10, 2)
  contractedAt                  DateTime           @default(now())
  internalNotes                 String?
  startedAt                     DateTime?
  nextBillingDate               DateTime?
  canceledAt                    DateTime?
  accessUntil                   DateTime?
  gracePeriodDays               Int                @default(5)
  blockedAt                     DateTime?
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  billingInvoices BillingInvoice[]

  @@unique([mercadoPagoSubscriptionId])
  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model PaymentWebhookLog {
  id          String    @id @default(uuid())
  provider    String
  eventId     String?
  eventType   String?
  resourceId  String?
  payload     Json?
  processed   Boolean   @default(false)
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@unique([provider, eventId])
  @@index([provider])
  @@index([resourceId])
  @@map("payment_webhook_logs")
}

model Category {
  id                   String       @id @default(uuid())
  tenantId             String
  name                 String
  slug                 String
  type                 CategoryType @default(PRODUCT_SECTION)
  defaultImageUrl      String?
  defaultImagePublicId String?
  sortOrder            Int          @default(0)
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products               Product[]
  productModifierOptions ProductModifierOption[]

  @@unique([tenantId, slug])
  @@map("categories")
}

model Product {
  id          String             @id @default(uuid())
  tenantId    String
  categoryId  String
  name        String
  description String?
  imageUrl    String?
  type        ProductType
  pricingMode ProductPricingMode @default(FIXED)
  basePrice   Decimal?           @db.Decimal(10, 2)
  price       Decimal?           @db.Decimal(10, 2)
  isActive    Boolean            @default(true)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  orderItems           OrderItem[]
  modifierGroups       ProductModifierGroup[]
  modifierOptions      ProductModifierOption[]
  modifierOptionRules  ProductModifierOptionRule[]
  modifierOptionPrices ModifierOptionPrice[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, isActive])
  @@index([tenantId, sortOrder])
  @@map("products")
}

model ModifierGroup {
  id          String  @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?

  selectionType ModifierSelectionType
  pricingMode   ModifierPricingMode   @default(ADDITIVE)

  minSelections Int     @default(0)
  maxSelections Int     @default(1)
  isRequired    Boolean @default(false)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  options            ModifierOption[]
  products           ProductModifierGroup[]
  productOptions     ProductModifierOption[]
  targetRules        ProductModifierOptionRule[] @relation("ProductModifierOptionRuleTargetGroup")
  orderItemModifiers OrderItemModifier[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, sortOrder])
  @@map("modifier_groups")
}

model ModifierOption {
  id       String @id @default(uuid())
  tenantId String
  groupId  String

  name        String
  code        String?
  description String?
  imageUrl    String?

  priceDelta Decimal @default(0) @db.Decimal(10, 2)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group  ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  productOptions     ProductModifierOption[]
  sourceRules        ProductModifierOptionRule[] @relation("ProductModifierOptionRuleSourceOption")
  contextualPrices   ModifierOptionPrice[]       @relation("ModifierOptionContextualPrices")
  dependentPrices    ModifierOptionPrice[]       @relation("ModifierOptionDependentPrices")
  orderItemModifiers OrderItemModifier[]

  @@unique([tenantId, groupId, name])
  @@index([tenantId])
  @@index([groupId])
  @@index([tenantId, isActive])
  @@index([tenantId, sortOrder])
  @@map("modifier_options")
}

model ProductModifierGroup {
  id              String @id @default(uuid())
  tenantId        String
  productId       String
  modifierGroupId String

  sortOrder Int @default(0)

  isRequiredOverride    Boolean?
  minSelectionsOverride Int?
  maxSelectionsOverride Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, modifierGroupId])
  @@index([tenantId])
  @@index([productId])
  @@index([modifierGroupId])
  @@index([tenantId, productId, sortOrder])
  @@map("product_modifier_groups")
}

model ProductModifierOption {
  id String @id @default(uuid())

  tenantId          String
  productId         String
  modifierGroupId   String
  modifierOptionId  String
  displayCategoryId String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  priceDeltaOverride Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup  @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  modifierOption  ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Cascade)
  displayCategory Category?      @relation(fields: [displayCategoryId], references: [id], onDelete: SetNull)

  @@unique([tenantId, productId, modifierOptionId])
  @@index([tenantId])
  @@index([productId])
  @@index([modifierGroupId])
  @@index([modifierOptionId])
  @@index([displayCategoryId])
  @@index([tenantId, productId, modifierGroupId])
  @@index([tenantId, productId, sortOrder])
  @@map("product_modifier_options")
}

model ProductModifierOptionRule {
  id String @id @default(uuid())

  tenantId       String
  productId      String
  sourceOptionId String
  targetGroupId  String

  isEnabled     Boolean @default(true)
  minSelections Int?
  maxSelections Int?
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceOption ModifierOption @relation("ProductModifierOptionRuleSourceOption", fields: [sourceOptionId], references: [id], onDelete: Cascade)
  targetGroup  ModifierGroup  @relation("ProductModifierOptionRuleTargetGroup", fields: [targetGroupId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, sourceOptionId, targetGroupId])
  @@index([tenantId])
  @@index([productId])
  @@index([sourceOptionId])
  @@index([targetGroupId])
  @@index([tenantId, productId])
  @@map("product_modifier_option_rules")
}

model ModifierOptionPrice {
  id String @id @default(uuid())

  tenantId  String
  productId String

  modifierOptionId  String
  dependsOnOptionId String?

  price    Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  modifierOption  ModifierOption  @relation("ModifierOptionContextualPrices", fields: [modifierOptionId], references: [id], onDelete: Cascade)
  dependsOnOption ModifierOption? @relation("ModifierOptionDependentPrices", fields: [dependsOnOptionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, modifierOptionId, dependsOnOptionId])
  @@index([tenantId])
  @@index([productId])
  @@index([modifierOptionId])
  @@index([dependsOnOptionId])
  @@index([tenantId, productId])
  @@map("modifier_option_prices")
}

model Order {
  id                       String       @id @default(uuid())
  tenantId                 String
  userId                   String?
  number                   Int          @default(autoincrement())
  customerName             String?
  customerPhone            String?
  type                     OrderType
  status                   OrderStatus  @default(PENDING)
  paymentType              PaymentType?
  subtotal                 Decimal      @db.Decimal(10, 2)
  deliveryFee              Decimal      @default(0) @db.Decimal(10, 2)
  discountAmount           Decimal      @default(0) @db.Decimal(10, 2)
  couponCode               String?
  totalBeforeDiscount      Decimal?     @db.Decimal(10, 2)
  total                    Decimal      @db.Decimal(10, 2)
  notes                    String?
  privacyAcceptedAt        DateTime?
  privacyPolicyVersion     String?
  privacyAcceptedIp        String?
  privacyAcceptedUserAgent String?
  paidAt                   DateTime?
  closedAt                 DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  items OrderItem[]
  whatsappNotifications WhatsAppNotification[]

  @@map("orders")
}

model WhatsAppConnection {
  id                String                   @id @default(uuid())
  tenantId          String                   @unique
  provider          WhatsAppProvider         @default(EVOLUTION_API)
  automationEnabled Boolean                  @default(false)
  status            WhatsAppConnectionStatus @default(DISCONNECTED)
  instanceName      String?
  connectedPhone    String?
  enabledEvents     WhatsAppEventType[]       @default([ORDER_CONFIRMED, ORDER_CANCELLED, ORDER_READY, ORDER_OUT_FOR_DELIVERY])
  lastError         String?
  lastConnectedAt   DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("whatsapp_connections")
}

model WhatsAppNotification {
  id                String                     @id @default(uuid())
  tenantId          String
  orderId           String?
  eventType         WhatsAppEventType
  status            WhatsAppNotificationStatus @default(PENDING)
  dedupeKey         String                     @unique
  recipient         String?
  providerMessageId String?
  attempts          Int                        @default(0)
  error             String?
  scheduledAt       DateTime?
  sentAt            DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([status, scheduledAt])
  @@index([orderId])
  @@map("whatsapp_notifications")
}

model Coupon {
  id                String     @id @default(uuid())
  tenantId          String
  code              String
  type              CouponType
  value             Decimal    @db.Decimal(10, 2)
  minimumOrderValue Decimal?   @db.Decimal(10, 2)
  startsAt          DateTime?
  expiresAt         DateTime?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("coupons")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  productId  String?
  name       String
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)
  notes      String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderItemModifier {
  id String @id @default(uuid())

  orderItemId String

  modifierGroupId  String?
  modifierOptionId String?

  groupName  String
  groupCode  String?
  optionName String
  optionCode String?

  pricingMode ModifierPricingMode?

  quantity          Int      @default(1)
  fraction          Decimal? @db.Decimal(5, 2)
  dependsOnOptionId String?
  metadata          Json?

  unitPriceDelta Decimal @default(0) @db.Decimal(10, 2)
  totalDelta     Decimal @default(0) @db.Decimal(10, 2)

  sortOrder Int @default(0)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  modifierGroup  ModifierGroup?  @relation(fields: [modifierGroupId], references: [id], onDelete: SetNull)
  modifierOption ModifierOption? @relation(fields: [modifierOptionId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([modifierGroupId])
  @@index([modifierOptionId])
  @@index([orderItemId, sortOrder])
  @@map("order_item_modifiers")
}

enum CategoryType {
  PRODUCT_SECTION
  PIZZA_FLAVOR_GROUP
}

enum TenantSegment {
  PIZZARIA
  HAMBURGUERIA
  ACAITERIA
  PASTELARIA
}

enum ModifierSelectionType {
  SINGLE
  MULTIPLE
}

enum ModifierPricingMode {
  INCLUDED
  ADDITIVE
  REPLACE_BASE
  HIGHEST_SELECTED
}

enum ProductPricingMode {
  FIXED
  FROM_MODIFIERS
}

enum UserRole {
  MASTER_OWNER
  MASTER_ADMIN
  FINANCE_ADMIN
  SUPPORT
  CLIENT_OWNER
  CLIENT_ADMIN
  CASHIER
}

enum ProductType {
  PIZZA_ROUND
  PIZZA_SQUARE
  DRINK
  OTHER
}

enum OrderType {
  ONLINE
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum WhatsAppProvider {
  EVOLUTION_API
}

enum WhatsAppConnectionStatus {
  DISCONNECTED
  AWAITING_CONFIGURATION
  CONNECTED
  ERROR
}

enum WhatsAppEventType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  ORDER_READY
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  TEST
}

enum WhatsAppNotificationStatus {
  PENDING
  PROCESSING
  SENT
  DRY_RUN
  SKIPPED
  FAILED
}

enum PaymentType {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum AuditLogLevel {
  INFO
  WARNING
  CRITICAL
}

enum BillingInvoiceStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

enum BillingPaymentMethod {
  MERCADO_PAGO
  MANUAL
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCEL_SCHEDULED
  CANCELED
  BLOCKED
}
