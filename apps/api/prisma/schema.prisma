generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  document  String?
  phone     String?
  whatsapp  String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  categories Category[]
  products   Product[]
  orders     Order[]
  tables     RestaurantTable[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String
  password  String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([tenantId, email])
  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  slug      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
  @@map("categories")
}

model Product {
  id          String      @id @default(uuid())
  tenantId    String
  categoryId  String
  name        String
  description String?
  imageUrl    String?
  type        ProductType
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  sizes        PizzaSize[]
  flavorPrices PizzaFlavorPrice[]
  borderPrices PizzaBorderPrice[]
  orderItems   OrderItem[]

  @@map("products")
}

model PizzaSize {
  id          String        @id @default(uuid())
  tenantId    String
  productId   String
  name        String
  type        PizzaSizeType
  value       Int?
  maxFlavors  Int           @default(1)
  allowBorder Boolean       @default(true)
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  flavorPrices PizzaFlavorPrice[]
  borderPrices PizzaBorderPrice[]

  @@map("pizza_sizes")
}

model PizzaFlavor {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prices     PizzaFlavorPrice[]
  orderItems OrderItemFlavor[]

  @@unique([tenantId, name])
  @@map("pizza_flavors")
}

model PizzaFlavorPrice {
  id        String  @id @default(uuid())
  tenantId  String
  productId String
  sizeId    String
  flavorId  String
  price     Decimal @db.Decimal(10, 2)

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size    PizzaSize   @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  flavor  PizzaFlavor @relation(fields: [flavorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, sizeId, flavorId])
  @@map("pizza_flavor_prices")
}

model PizzaBorder {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices PizzaBorderPrice[]

  @@unique([tenantId, name])
  @@map("pizza_borders")
}

model PizzaBorderPrice {
  id        String  @id @default(uuid())
  tenantId  String
  productId String
  sizeId    String
  borderId  String
  price     Decimal @db.Decimal(10, 2)

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size    PizzaSize   @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  border  PizzaBorder @relation(fields: [borderId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, sizeId, borderId])
  @@map("pizza_border_prices")
}

model RestaurantTable {
  id        String      @id @default(uuid())
  tenantId  String
  number    Int
  name      String?
  status    TableStatus @default(AVAILABLE)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([tenantId, number])
  @@map("restaurant_tables")
}

model Order {
  id            String      @id @default(uuid())
  tenantId      String
  userId        String?
  tableId       String?
  customerName  String?
  customerPhone String?
  type          OrderType
  status        OrderStatus @default(PENDING)
  paymentType   PaymentType?
  subtotal      Decimal     @db.Decimal(10, 2)
  deliveryFee   Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  table  RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String?
  sizeId     String?
  borderId   String?
  name       String
  sizeName   String?
  borderName String?
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  notes      String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  flavors OrderItemFlavor[]

  @@map("order_items")
}

model OrderItemFlavor {
  id          String  @id @default(uuid())
  orderItemId String
  flavorId    String?
  flavorName  String
  fraction    Decimal @db.Decimal(5, 2)

  orderItem OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  flavor    PizzaFlavor? @relation(fields: [flavorId], references: [id], onDelete: SetNull)

  @@map("order_item_flavors")
}

enum UserRole {
  MASTER_OWNER
  MASTER_ADMIN
  CLIENT_OWNER
  CLIENT_ADMIN
  WAITER
  KITCHEN
  CASHIER
}

enum ProductType {
  PIZZA_ROUND
  PIZZA_SQUARE
  DRINK
  OTHER
}

enum PizzaSizeType {
  CM
  SLICES
  CUSTOM
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  CLOSED
}

enum OrderType {
  ONLINE
  TABLE
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_KITCHEN
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentType {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}